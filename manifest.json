{
  "manifest_version": 3,
  "name": "PagePal – תרגם וסכם כל עמוד",
  "version": "3.2.1",
  "description": "PagePal: תרגום לעברית, סיכום וצ'אט עם כל עמוד. Chrome Local AI + Gemini + ChatGPT + Perplexity.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "commands",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "host_permissions": [
    "https://api.perplexity.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.lemonsqueezy.com/*"
  ],
  "commands": {
    "open-translator": {
      "suggested_key": {
        "mac": "Command+Shift+Y",
        "windows": "Ctrl+Shift+Y",
        "linux": "Ctrl+Shift+Y"
      },
      "description": "פתח את AI Translator"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["modal.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
